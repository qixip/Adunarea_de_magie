# ── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript \
                                application/json text/plain text/xml \
                                application/xml image/svg+xml font/woff font/woff2
</IfModule>

# ── Browser Caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed assets (Angular outputHashing=all) — safe to cache 1 year
  <FilesMatch "\.[0-9A-Z]{8}\.(js|css)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Fonts — content rarely changes
  ExpiresByType font/woff2                  "access plus 1 year"
  ExpiresByType font/woff                   "access plus 1 year"
  ExpiresByType font/ttf                    "access plus 1 year"
  ExpiresByType application/font-woff       "access plus 1 year"
  ExpiresByType application/font-woff2      "access plus 1 year"

  # Images — 30 days (gallery may get new photos)
  ExpiresByType image/jpeg                  "access plus 30 days"
  ExpiresByType image/png                   "access plus 30 days"
  ExpiresByType image/webp                  "access plus 30 days"
  ExpiresByType image/svg+xml               "access plus 30 days"
  ExpiresByType image/x-icon                "access plus 30 days"
</IfModule>

# ── No-cache for index.html (Angular app shell must always be fresh) ──────────
<FilesMatch "^index\.html$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </IfModule>
</FilesMatch>

# ── Routing ───────────────────────────────────────────────────────────────────
RewriteEngine On

# Route all /api/* requests through the PHP front controller
RewriteCond %{REQUEST_URI} ^/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ api/index.php [L]

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Angular catch-all
RewriteRule ^ index.html [L]
